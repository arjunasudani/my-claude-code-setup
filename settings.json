{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Bash(npm init:*)",
      "Bash(node -e ':*)",
      "Bash(sips -g pixelWidth -g pixelHeight www.variance.com_blog_announcing-our-raise.png)",
      "Bash(npx -y puppeteer --help)",
      "Bash(npm pkg *)",
      "Bash(node shot.mjs shot1.png)",
      "Bash(python3 -c ' *)",
      "Bash(node shot.mjs shot2.png)",
      "Bash(node shot.mjs shot3.png)",
      "Bash(python3)",
      "Bash(node shot.mjs shot5.png)",
      "Bash(node shot.mjs shot6.png)",
      "Bash(node shot.mjs shot8.png)",
      "Bash(node shot.mjs 375 /tmp/mob.png)",
      "Bash(node shot.mjs 768 /tmp/tab.png)",
      "Bash(node shot.mjs 1280 /tmp/desk.png)",
      "Bash(npx -y puppeteer screenshot index.html screenshot1.png --viewport=1728x960 --full-page)",
      "Bash(node /Users/arjunasudani/Desktop/claude-code/screenshot.cjs)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/arjunasudani/.claude/scripts/hooks/session-start.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/mcp-tool-count.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/skill-reminder.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/tmux-reminder.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/git-push-review.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/block-md-files.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/arjunasudani/.claude/skills/continuous-learning-v2/hooks/observe.sh pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/prettier-format.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/tsc-check.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/console-log-warn.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/arjunasudani/.claude/hooks/ecc-metrics-bridge.js"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/arjunasudani/.claude/skills/continuous-learning-v2/hooks/observe.sh post"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/arjunasudani/.claude/hooks/console-log-audit.py"
          },
          {
            "type": "command",
            "command": "node /Users/arjunasudani/.claude/scripts/hooks/session-end.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/arjunasudani/.claude/scripts/hooks/pre-compact.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/arjunasudani/.claude/hooks/ecc-statusline.js"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "zapier@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "mgrep@Mixedbread-Grep": true
  },
  "extraKnownMarketplaces": {
    "Mixedbread-Grep": {
      "source": {
        "source": "git",
        "url": "https://github.com/mixedbread-ai/mgrep.git"
      }
    }
  },
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
